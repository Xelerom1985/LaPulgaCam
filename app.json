{
  "expo": {
    "name": "LaPulgaCam",
    "slug": "LaPulgaCamApp",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.lapulgacam.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Permite guardar los videos del partido en tu galería",
          "savePhotosPermission": "Permite guardar los videos del partido en tu galería"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite elegir el escudo del equipo desde tu galería"
        }
      ],
      [
        "expo-av",
        {}
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false
          }
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "6439093b-01cc-4380-89dd-1aaf2fc71f13"
      }
    },
    "owner": "xelerom"
  }
}
